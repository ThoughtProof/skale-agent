# ThoughtProof SKALE Agent Configuration

# ThoughtProof API key (get from dashboard.thoughtproof.ai)
THOUGHTPROOF_API_KEY=tp_...

# Wallet private key (for x402 payments and ERC-8004 registration)
PRIVATE_KEY=0x...

# Address to receive x402 payments (server mode)
RECEIVING_ADDRESS=0x...

# Server URL (client mode)
SERVER_URL=http://localhost:3000

# Server port
PORT=3000
